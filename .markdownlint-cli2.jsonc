// Enforce only the 80-column line-length rule (MD013), to mirror Google's
// internal Markdown linter. All other rules are disabled.
{
  "config": {
    "default": false,
    "MD013": {
      "line_length": 80,
      // Don't flag long lines in code blocks or tables (often unwrappable).
      "code_blocks": false,
      "tables": false
    }
  },
  "ignores": [
    "**/node_modules/**",
    "docs/_build/**"
  ]
}
